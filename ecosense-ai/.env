# ===========================================
# EcoSense AI — Root Environment Variables
# Used by docker-compose.prod.yml
# ===========================================

# PostgreSQL
DB_USER=ecosense
DB_PASSWORD=ecosense_prod_password_change_me
DB_NAME=ecosense

# Django
SECRET_KEY=change-me-to-a-real-secret-key-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost

# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Blockchain
POLYGON_PRIVATE_KEY=your-polygon-private-key
