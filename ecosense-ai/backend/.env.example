# ===========================================
# EcoSense AI — Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ===========================================

# Django
SECRET_KEY=your-value-here
DEBUG=your-value-here
ALLOWED_HOSTS=your-value-here
CORS_ALLOWED_ORIGINS=your-value-here
FRONTEND_URL=your-value-here

# Database (PostgreSQL + PostGIS)
DATABASE_URL=your-value-here

# Redis (Cache + Celery Broker)
REDIS_URL=your-value-here

# AWS
AWS_ACCESS_KEY_ID=your-value-here
AWS_SECRET_ACCESS_KEY=your-value-here
AWS_S3_BUCKET=your-value-here

# Mapbox
MAPBOX_TOKEN=your-value-here

# OpenAI / LangChain
OPENAI_API_KEY=your-value-here

# Google Earth Engine
GEE_SERVICE_ACCOUNT=your-value-here

# Africa's Talking (SMS / WhatsApp)
AFRICAS_TALKING_API_KEY=your-value-here
AFRICAS_TALKING_USERNAME=your-value-here

# Twilio (WhatsApp Fallback)
TWILIO_ACCOUNT_SID=your-value-here
TWILIO_AUTH_TOKEN=your-value-here

# Blockchain (Polygon)
POLYGON_RPC_URL=your-value-here
POLYGON_CONTRACT_ADDRESS=your-value-here
POLYGON_PRIVATE_KEY=your-value-here
